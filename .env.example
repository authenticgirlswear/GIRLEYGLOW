# ===================================================
# Environment variables reference
#
# Copy this file to .env for local development (npm run dev),
# AND add the same keys to Vercel: Project Settings > Environment
# Variables, so they're available when deployed.
#
# Never commit the real .env file — it's already in .gitignore.
# ===================================================

# ── Frontend (Vite — exposed to the browser, must be prefixed VITE_) ──
# These should already exist in your project from earlier setup.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe (server-side only — used by /api functions) ──
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Get this after creating a webhook endpoint:
# Stripe Dashboard > Developers > Webhooks > Add endpoint
# URL: https://yourdomain.com/api/stripe-webhook, event: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── SSLCommerz (server-side only — used by /api functions) ──
# Get sandbox credentials instantly at https://developer.sslcommerz.com
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
# 'true' while testing against the sandbox, 'false' once you have a live/approved account
SSLCOMMERZ_IS_SANDBOX=true

# ── Supabase (server-side only — used by /api functions to update orders) ──
# Get this from Supabase Dashboard > Project Settings > API > service_role key
# This key bypasses Row Level Security — NEVER expose it in frontend code,
# NEVER prefix it with VITE_, only use it inside /api functions.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Shared ──
# Your deployed site URL, used to build redirect URLs for both gateways.
PUBLIC_SITE_URL=https://girleyglow-seven.vercel.app
